# Copy to `festers.env` on the box and fill in. NEVER commit the real file.
# These are the env vars the app actually reads (see festers/app.py, notify.py).

# --- required in prod ---
# HMAC key for plan-id fingerprints. Long random value. If it changes, every
# existing magic link / plan id breaks - set once and keep it.
FESTERS_SECRET=change-me-to-a-long-random-string

# Public URL used to build magic links, e.g. https://festers.dynamicalsystem.com
FESTERS_BASE_URL=https://festers.dynamicalsystem.com

# --- host wiring (consumed by docker-compose.yml, not the app) ---
# Loopback port Caddy proxies to. Must match the port in festers.caddy.
FESTERS_PORT=8000
# Image tag to run; `latest` tracks main. Pin to a sha for a controlled rollback.
FESTERS_TAG=latest

# --- notifications: console | signal | smtp (default console = logs the link) ---
FESTERS_NOTIFIER=console

# signal (FESTERS_NOTIFIER=signal): point at the shared signal-cli-rest-api.
# From a host service, that's loopback; the shared sender's E.164 number.
#FESTERS_SIGNAL_URL=http://127.0.0.1:8010
#FESTERS_SIGNAL_FROM=+440000000000

# smtp (FESTERS_NOTIFIER=smtp): e.g. Gmail + an app password.
#FESTERS_SMTP_HOST=smtp.gmail.com
#FESTERS_SMTP_PORT=587
#FESTERS_SMTP_USER=you@example.com
#FESTERS_SMTP_PASS=app-password
#FESTERS_SMTP_FROM=festers@example.com
