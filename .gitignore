# python
__pycache__/
*.pyc
.venv/
venv/
.pytest_cache/

# local env / secrets
.env
# on-box deploy secrets - never commit (only the .example is tracked)
deploy/festers.env
# on-box runtime marker written by update.sh
deploy/.last-failed-digest
# OCI credentials - never commit
.oci/

# os
.DS_Store

# tooling
.claude/
.mount-probe

# runtime data, not source
# persisted user plans (Contract B)
data/plans/*.json
# runtime auth token store
data/auth/

# source material (regenerable / not committed by convention)
sources/

# working journal (ephemeral WIP meta)
NIGHT-LOG.md
