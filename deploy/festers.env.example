# Copy to `festers.env` on the box and fill in. NEVER commit the real file.
# These are the env vars the app actually reads (see festers/app.py, notify.py).

# --- required in prod ---
# HMAC key for plan-id fingerprints. Long random value. If it changes, every
# existing magic link / plan id breaks - reuse the live value, set once.
FESTERS_SECRET=change-me-to-a-long-random-string

# Public URL used to build magic links.
FESTERS_BASE_URL=https://festers.dynamicalsystem.com

# --- notifications: console | signal | smtp (default console = logs the link) ---
FESTERS_NOTIFIER=console

# signal: point at the shared signal-cli-rest-api. NOTE: festers is now a
# CONTAINER, so `127.0.0.1` is the container's own loopback, NOT the host. To
# reach the host-published signal port use host.containers.internal, or put this
# container on signal's podman network and use its name. Confirm which on the box.
#FESTERS_SIGNAL_URL=http://host.containers.internal:8010
#FESTERS_SIGNAL_FROM=+440000000000

# smtp: e.g. Gmail + an app password.
#FESTERS_SMTP_HOST=smtp.gmail.com
#FESTERS_SMTP_PORT=587
#FESTERS_SMTP_USER=you@example.com
#FESTERS_SMTP_PASS=app-password
#FESTERS_SMTP_FROM=festers@example.com
